# StreamCap runtime environment configuration
# PLATFORM: Runtime platform for the application, supports 'desktop' or 'web' modes (default: web)
PLATFORM=web

# Set timezone
TZ=Asia/Shanghai

# HOST: Web server host address (default: 127.0.0.1 for local, 0.0.0.0 for server)
HOST=0.0.0.0

# PORT: Web server port number (default: 55554)
PORT=55554

# VIDEO_API_PORT: Web video server api port number (default: 17878)
VIDEO_API_PORT=17878

# LOGIN_REQUIRED: Enable web security login (true/false)
LOGIN_REQUIRED=true

# WEB_AUTH_USERNAME / WEB_AUTH_PASSWORD: Initial or forced web login credentials
WEB_AUTH_USERNAME=admin
WEB_AUTH_PASSWORD=admin

# Set web video storage directory
CUSTOM_VIDEO_ROOT_DIR=

# Set external URL for the video API (example: http://www.example.com)
VIDEO_API_EXTERNAL_URL=

# Enable automatic update check (true/false)
AUTO_CHECK_UPDATE=false

# Update source priority (github, custom, both)
UPDATE_SOURCE=both

# GitHub repository for updates
GITHUB_REPO=ihmily/StreamCap

# Custom update API URL (leave empty to disable)
CUSTOM_UPDATE_API=

# Update check interval in seconds (default: 86400 = 1 day)
UPDATE_CHECK_INTERVAL=86400
